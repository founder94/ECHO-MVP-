# ── ECHO MVP Production: Environment Variables ──
# Copy this file to .env and fill in your values
# cp .env.example .env

# ── Supabase ──
# Supabase Project URL (required)
VITE_PUBLIC_SUPABASE_URL=

# Supabase Anon / Public Key (required, publishable — safe in frontend)
VITE_PUBLIC_SUPABASE_ANON_KEY=

# ── Site ──
# Production deployment URL (optional, used for canonical links / OG tags)
VITE_PUBLIC_SITE_URL=

# ── AI ──
# OpenAI API Key (required for AI features)
# ⚠️ DO NOT put the real key here — store it in Supabase Secrets as OPENAI_API_KEY
# The Edge Function reads it via Deno.env.get('OPENAI_API_KEY')

# ── Payments ──
# Stripe Secret Key (required for payment features)
# ⚠️ DO NOT put the real key here — store it in Supabase Secrets as STRIPE_SECRET_KEY

# Toss Payments Secret Key (optional, Korean payment gateway)
# ⚠️ DO NOT put the real key here — store it in Supabase Secrets

# Stripe Webhook Signing Secret (required for payment completion)
# ⚠️ Store in Supabase Secrets as STRIPE_WEBHOOK_SECRET